        <mxCell id="J-MjveByyJUr8qswm52i-82" value="&lt;p class=&quot;MsoNormal&quot;&gt;&lt;span style=&quot;font-size: 14px;&quot;&gt;&lt;font style=&quot;font-size: 14px;&quot; face=&quot;Times New Roman&quot;&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;整理&lt;/font&gt;2000&lt;font style=&quot;font-size: 14px;&quot;&gt;—&lt;/font&gt;2025&lt;font style=&quot;font-size: 14px;&quot;&gt;年公开文献&lt;/font&gt;75&lt;font style=&quot;font-size: 14px;&quot;&gt;篇并用&lt;/font&gt;WebPlotDigitizer&lt;font style=&quot;font-size: 14px;&quot;&gt;提取与标准化得到&lt;/font&gt;dataset1&lt;font style=&quot;font-size: 14px;&quot;&gt;（&lt;/font&gt;1710 &lt;font style=&quot;font-size: 14px;&quot;&gt;组数据），将实验工况&lt;/font&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;与材料性质&lt;/font&gt;/&lt;font style=&quot;font-size: 14px;&quot;&gt;组成信息&lt;/font&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;耦合建模&lt;/font&gt;&lt;/font&gt;&lt;/span&gt;&lt;/p&gt;" style="whiteSpace=wrap;html=1;rounded=0;fillColor=#dae8fc;gradientColor=#7ea6e0;strokeColor=#6c8ebf;" parent="1" vertex="1">
